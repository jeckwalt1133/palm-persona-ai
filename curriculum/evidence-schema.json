{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-teacher-student.org/evidence-schema.json",
  "title": "AI师生研究院 证据标准 Schema",
  "description": "每个毕业等级的evidence从此Schema定义，替代自由文本。给人读的 graduation-ladder.json 保持简洁，本文件给脚本验证用。",
  "type": "object",
  "properties": {
    "claim": {
      "type": "string",
      "description": "学生声称的成就（一句话）"
    },
    "evidenceItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "url", "test", "data", "git"],
            "description": "证据类型"
          },
          "target": {
            "type": "string",
            "description": "证据目标路径/URL/命令"
          },
          "description": {
            "type": "string",
            "description": "这份证据证明什么"
          },
          "depthChecks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["check", "type"],
              "properties": {
                "check": {"type": "string", "description": "检查描述"},
                "type": {
                  "type": "string",
                  "enum": ["file_exists", "min_bytes", "min_lines", "min_sections", "pattern_match", "http_status", "test_pass_count", "git_commit_exists", "content_hash"]
                },
                "threshold": {"type": ["string", "number"], "description": "阈值"},
                "pattern": {"type": "string", "description": "pattern_match时的正则"}
              }
            }
          }
        }
      }
    },
    "verifiedBy": {
      "type": "string",
      "enum": ["auto", "teacher", "guest-wang", "guest-zhou", "peer-student"],
      "description": "谁验证的"
    },
    "verifiedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "验证时间（null=未验证）"
    },
    "verificationResult": {
      "type": "string",
      "enum": ["unverified", "passed", "failed", "expired"],
      "description": "验证结果"
    },
    "verificationNotes": {
      "type": "string",
      "description": "验证备注"
    },
    "expiresAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "证据过期时间（URL可能失效/测试可能过期）"
    }
  }
}
